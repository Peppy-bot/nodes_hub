{
  schema_version: 1,
  manifest: {
    name: "openarm01_arm",
    tag: "0.1.0",
    variants: [
      {
        name: "default",
        source: {
          local: "./variants/default"
        }
      },
      {
        name: "mock-rust",
        source: {
          local: "./variants/mock_rust"
        }
      },
      {
        name: "mock-python",
        source: {
          local: "./variants/mock_python"
        }
      },
    ]
  },
  interfaces: {
    topics: {
      emits: [
        {
          name: "joint_states",
          qos_profile: "sensor_data",
          message_format: {
            positions: {
              $type: "array",
              $items: "f64",
              $length: 3
            },
            velocities: {
              $type: "array",
              $items: "f64",
              $length: 3
            },
            timestamp: "time"
          }
        }
      ],
      consumes: [
        {
          // No local_node_id — this is an external consumed topic
          name: "joint_commands",
          message_format: {
            target_positions: {
              $type: "array",
              $items: "f64",
              $length: 3
            },
            max_velocity: "f64"
          }
        }
      ],
    },
  }
}