{
  schema_version: 1,
  manifest: {
    name: "robot_brain_etcher1",
    tag: "0.1.0",
    labels: [
      "brain"
    ],
    depends_on: {
      nodes: [
        {
          name: "uvc_camera",
          tag: "0.1.0",
          local_id: "camera_stream"
        },
        {
          name: "openarm01_controller",
          tag: "0.1.0",
          local_id: "robot_controller"
        }
      ]
    },
    variants: [
      {
        name: "default",
        source: {
          local: "./variants/default"
        }
      },
      {
        name: "mock-rust",
        source: {
          local: "./variants/mock_rust"
        }
      },
      {
        name: "mock-python",
        source: {
          local: "./variants/mock_python"
        }
      },
    ]
  },
  interfaces: {
    topics: {
      // The brain receives the inputs from the camera
      consumes: [
        {
          local_node_id: "camera_stream",
          name: "video_stream",
        },
      ],
    },
    services: {
      consumes: [
        {
          local_node_id: "camera_stream",
          name: "video_stream_info",
        },
      ]
    },
    actions: {
      consumes: [
        {
          local_node_id: "robot_controller",
          name: "move_right_arm"
        },
        {
          local_node_id: "robot_controller",
          name: "move_left_arm"
        }
      ]
    }
  }
}