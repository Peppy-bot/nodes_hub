Bootstrap: docker
From: tuatini/peppy-rust-cargo-base:latest

%labels
    Name uvc_camera
    Version 0.1.0

%files
    . /opt/uvc_camera

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends pkg-config libclang-dev

    cd /opt/uvc_camera
    cargo build --release

%runscript
    cd /opt/uvc_camera
    exec ./target/release/uvc_camera
