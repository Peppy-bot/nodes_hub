Bootstrap: docker
From: tuatini/peppy-rust-cargo-base:latest

%labels
    Name uvc_camera_controls_tests
    Version 0.1.0

%files
    . /opt/uvc_camera_controls_tests

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
	libclang-dev libavutil-dev libavformat-dev libavcodec-dev libavfilter-dev \
	libavdevice-dev libswscale-dev libswresample-dev libpostproc-dev
    rm -rf /var/lib/apt/lists/*

    cd /opt/uvc_camera_controls_tests
    cargo build --release

%runscript
    cd /opt/uvc_camera_controls_tests
    exec ./target/release/uvc_camera_controls_tests
