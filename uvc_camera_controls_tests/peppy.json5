{
  schema_version: 1,
  manifest: {
    name: "uvc_camera_controls_tests",
    tag: "0.1.0",
    language: "rust",
    depends_on: {
      nodes: [
        {
          name: "uvc_camera",
          tag: "0.1.0",
          local_id: "camera"
        },
      ]
    }
  },
  container: {
    def_file: "apptainer.def"
  },
  interfaces: {
    topics: {
      consumes: [
        {
          local_node_id: "camera",
          name: "video_stream"
        },
      ]
    },
    services: {
      consumes: [
        {
          local_node_id: "camera",
          name: "video_stream_info"
        },
        {
          local_node_id: "camera",
          name: "set_exposure"
        },
        {
          local_node_id: "camera",
          name: "set_white_balance"
        },
        {
          local_node_id: "camera",
          name: "set_gain"
        },
        {
          local_node_id: "camera",
          name: "set_brightness"
        },
        {
          local_node_id: "camera",
          name: "set_contrast"
        },
      ]
    }
  }
}