Bootstrap: docker
From: tuatini/peppy-rust-cargo-base:latest

%labels
    Name uvc_camera_video_reconstruction
    Version 0.1.0

%environment
    export PATH="/root/.cargo/bin:$PATH"

%files
    . /opt/uvc_camera_video_reconstruction

%post
    set -eux

    apt-get update
    apt-get install -y --no-install-recommends \
        ffmpeg \
        libavdevice-dev \
        libavcodec-dev \
        libavformat-dev \
        libavutil-dev \
        libswscale-dev \
        libdav1d-dev \
        libswresample-dev \
        libavfilter-dev \
        clang \
        libclang-dev \
        llvm-dev
    rm -rf /var/lib/apt/lists/*

    cd /opt/uvc_camera_video_reconstruction
    cargo build --release

%runscript
    cd /opt/uvc_camera_video_reconstruction
    exec ./target/release/uvc_camera_video_reconstruction